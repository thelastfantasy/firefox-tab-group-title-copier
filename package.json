{
  "name": "firefox-tab-group-title-copier",
  "version": "1.2.0",
  "description": "Firefox extension to copy all tab titles from tab groups",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\"",
    "typecheck": "tsc --noEmit",
    "package": "npm run build && web-ext build --source-dir=dist --overwrite-dest",
    "dev": "npm run build && web-ext run --source-dir=dist"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "web-ext": "^8.3.0"
  }
}
